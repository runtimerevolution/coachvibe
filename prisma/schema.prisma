generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model Coach {
  id           String   @id @default(cuid())
  name         String   @default("Coach")
  email        String   @unique
  password     String?
  onboarded    Boolean  @default(false)
  bio          String?
  imageUrl     String?
  websiteUrl   String?
  personality  String?
  goals        String[]
  hoursPerWeek Int      @default(5)
  credits      Int      @default(500)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  products         Product[]
  integrations     Integration[]
  workflows        WorkflowInstance[]
  landingPages     LandingPage[]
  notifications    Notification[]
  activityLogs     ActivityLog[]
  chatMessages     ChatMessage[]
  conciergeTasks   ConciergeTask[]
  knowledgeEntries KnowledgeEntry[]
}

model Product {
  id          String   @id @default(cuid())
  coachId     String
  coach       Coach    @relation(fields: [coachId], references: [id], onDelete: Cascade)
  name        String
  description String   @default("")
  price       Float    @default(0)
  type        String   @default("lead_magnet")
  modules     String[]
  embedScript String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  landingPage LandingPage?
}

model LandingPage {
  id          String   @id @default(cuid())
  productId   String   @unique
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  coachId     String
  coach       Coach    @relation(fields: [coachId], references: [id], onDelete: Cascade)
  slug        String   @unique
  data        Json
  published   Boolean  @default(false)
  generatedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Integration {
  id           String   @id @default(cuid())
  coachId      String
  coach        Coach    @relation(fields: [coachId], references: [id], onDelete: Cascade)
  service      String
  connected    Boolean  @default(false)
  accessToken  String?
  refreshToken String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([coachId, service])
}

model WorkflowInstance {
  id                String   @id @default(cuid())
  coachId           String
  coach             Coach    @relation(fields: [coachId], references: [id], onDelete: Cascade)
  templateId        String
  active            Boolean  @default(false)
  customName        String?
  customDescription String?
  customSteps       Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  runs WorkflowRun[]

  @@unique([coachId, templateId])
}

model WorkflowRun {
  id          String           @id @default(cuid())
  workflowId  String
  workflow    WorkflowInstance @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  status      String           @default("completed")
  creditCost  Int              @default(0)
  output      Json?
  startedAt   DateTime         @default(now())
  completedAt DateTime?
}

model Notification {
  id        String   @id @default(cuid())
  coachId   String
  coach     Coach    @relation(fields: [coachId], references: [id], onDelete: Cascade)
  title     String
  body      String
  type      String   @default("info")
  read      Boolean  @default(false)
  dismissed Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(cuid())
  coachId   String
  coach     Coach    @relation(fields: [coachId], references: [id], onDelete: Cascade)
  action    String
  label     String
  metadata  Json?
  createdAt DateTime @default(now())
}

model ChatMessage {
  id        String   @id @default(cuid())
  coachId   String
  coach     Coach    @relation(fields: [coachId], references: [id], onDelete: Cascade)
  role      String
  content   String
  createdAt DateTime @default(now())
}

model ConciergeTask {
  id          String    @id @default(cuid())
  coachId     String
  coach       Coach     @relation(fields: [coachId], references: [id], onDelete: Cascade)
  title       String
  description String?
  status      String    @default("pending")
  priority    String    @default("medium")
  source      String    @default("manual")
  dueDate     DateTime?
  points      Int       @default(10)
  timeMinutes Int       @default(15)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model KnowledgeEntry {
  id        String   @id @default(cuid())
  coachId   String
  coach     Coach    @relation(fields: [coachId], references: [id], onDelete: Cascade)
  title     String
  content   String
  tags      String[]
  source    String   @default("manual")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
