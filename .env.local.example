# Copy to .env.local and fill in your values:  cp .env.local.example .env.local
#
# This file holds app secrets read by Next.js. The DATABASE_URL does NOT go
# here — the Prisma CLI (migrate/seed/studio) only auto-loads `.env`, so it
# lives in `.env` (see .env.example). Next.js reads both files.

OPENAI_API_KEY=sk-...
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=...

# Optional: Firebase (for saving generated landing pages)
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=

# --- Nango integration layer (free Cloud plan) ---
# Environment Secret Key from the Nango dashboard → Environment Settings.
# Server-only — never prefix with NEXT_PUBLIC. Required for the Gmail / Google
# Calendar connectors and the "Run now (real)" workflow.
NANGO_SECRET_KEY=
NANGO_HOST=https://api.nango.dev

# Your own Google OAuth app credentials for the Nango Gmail/Calendar integrations.
# Reference only — CoachOS does NOT read these at runtime. Paste them into Nango's
# "Custom developer app" tab for each integration. Named NANGO_* so they aren't
# confused with the app-login GOOGLE_CLIENT_ID/SECRET.
NANGO_GOOGLE_CLIENT_ID=
NANGO_GOOGLE_CLIENT_SECRET=
