# Copy to .env.local and fill in your values.
#
# NOTE: the Prisma CLI (migrate/seed/studio) only auto-loads `.env`, NOT
# `.env.local`. Put DATABASE_URL in a `.env` file; Next.js reads both.
DATABASE_URL="postgresql://user:password@localhost:5432/coachos"

OPENAI_API_KEY=sk-...
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=...

# Optional: Firebase (for saving generated landing pages)
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=

# --- Nango integration layer (free Cloud plan) ---
# Environment Secret Key from the Nango dashboard → Environment Settings.
# Server-only — never prefix with NEXT_PUBLIC. Required for the Gmail / Google
# Calendar connectors and the "Run now (real)" workflow.
NANGO_SECRET_KEY=
NANGO_HOST=https://api.nango.dev
