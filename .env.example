# Copy to `.env`:  cp .env.example .env
#
# This file holds ONLY the database connection. The Prisma CLI
# (migrate / seed / studio) auto-loads `.env` but NOT `.env.local`,
# so DATABASE_URL must live here. App secrets go in `.env.local`
# (see .env.local.example).
#
# The default below matches the Postgres container in docker-compose.yml —
# no changes needed if you run the DB with `docker compose up -d`.
DATABASE_URL="postgresql://coachos:coachos@localhost:5432/coachos"
